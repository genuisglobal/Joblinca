### Supabase configuration
# Provide your Supabase project URL (e.g. https://xyzcompany.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public client key safe to expose in the browser. Use the publishable key from Supabase API settings.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret service role key for server‑side operations. Keep this key private and never commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=

# Optional API keys for global job providers.  Uncomment and fill
# these variables if you have access to additional job feeds.  When
# undefined the corresponding integrations are disabled.
# API key for Findwork job search API (https://findwork.dev/api/)
FINDWORK_API_KEY=
# Upwork OAuth client credentials (https://developers.upwork.com/)
UPWORK_CLIENT_ID=
UPWORK_CLIENT_SECRET=
# API key for other remote job providers (add as needed)

# OpenAI API key for resume optimisation (https://platform.openai.com/)
OPENAI_API_KEY=

# Payunit payment integration (https://payunit.net)
# These three credentials are only needed if this app talks to PayUnit directly
# or via the Supabase proxy. With the external fixed-IP proxy below, keep them
# on the proxy host instead of Vercel.
PAYUNIT_API_USER=
PAYUNIT_API_PASSWORD=
PAYUNIT_API_KEY=
PAYUNIT_MODE=test
PAYUNIT_BASE_URL=https://gateway.payunit.net
# Recommended for live traffic: route PayUnit through a fixed-IP backend service.
# Example: https://joblinca-payunit-proxy.fly.dev
PAYUNIT_PROXY_URL=
# Shared secret used by the external proxy service to authenticate requests from this app.
PAYUNIT_PROXY_SHARED_SECRET=
# Optional fallback: route PayUnit through the Supabase Edge Function proxy instead.
PAYUNIT_USE_SUPABASE_PROXY=false
# Optional fallback when carrier detection fails (e.g. CM_MTN or CM_ORANGE)
PAYUNIT_DEFAULT_GATEWAY=

# Public app URL used for webhook callbacks and redirects (must be HTTPS for Payunit)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret for non-Vercel scheduled jobs (for example GitHub Actions calling /api/cron/*)
CRON_SECRET=

# Matching agent delivery configuration
# Maximum number of subscribed profiles notified per newly-live job.
# Use all|0|-1 or leave empty to notify all matched subscribed users.
MATCHING_AGENT_MAX_RECIPIENTS=all
# Minimum match score (0-100). Leave empty to use role/job-type defaults.
MATCHING_AGENT_MIN_SCORE=
# Cron fallback lookback window in hours for recently approved jobs.
MATCHING_AGENT_CRON_LOOKBACK_HOURS=24
# Per-user throttling for job-match notifications.
MATCHING_AGENT_USER_DAILY_LIMIT=5
MATCHING_AGENT_USER_WEEKLY_LIMIT=30
# Daily deep backfill settings.
MATCHING_AGENT_DAILY_LOOKBACK_HOURS=168
MATCHING_AGENT_DAILY_JOB_LIMIT=250

# Email notifications for matched jobs (Resend)
RESEND_API_KEY=
MATCHING_EMAIL_FROM=alerts@joblinca.com
MATCHING_EMAIL_REPLY_TO=

# Interview scheduling automation
INTERVIEW_REMINDER_WINDOW_HOURS=4
WA_INTERVIEW_SCHEDULED_TEMPLATE=interview_scheduled_v1
WA_INTERVIEW_SCHEDULED_TEMPLATE_LANG=en
WA_INTERVIEW_REMINDER_TEMPLATE=interview_reminder_v1
WA_INTERVIEW_REMINDER_TEMPLATE_LANG=en
WA_INTERVIEW_RESCHEDULED_TEMPLATE=interview_rescheduled_v1
WA_INTERVIEW_RESCHEDULED_TEMPLATE_LANG=en
WA_INTERVIEW_CANCELLED_TEMPLATE=interview_cancelled_v1
WA_INTERVIEW_CANCELLED_TEMPLATE_LANG=en
