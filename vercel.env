NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PayUnit (Mobile Money payments)
# Get these from: https://pu.payunit.net -> Settings -> API Keys
PAYUNIT_API_USER=
PAYUNIT_API_PASSWORD=
# Get this from: pu.payunit.net -> your app -> Application Detail -> ID
PAYUNIT_API_KEY=
# live | test
PAYUNIT_MODE=live
PAYUNIT_BASE_URL=https://gateway.payunit.net
# Optional fixed-IP PayUnit proxy
PAYUNIT_PROXY_URL=https://joblinca-payunit-proxy.fly.dev
# Must match the proxy's PROXY_SHARED_SECRET
PAYUNIT_PROXY_SHARED_SECRET=
# Fallback gateway when carrier cannot be detected: CM_MTN | CM_ORANGE
PAYUNIT_DEFAULT_GATEWAY=CM_MTN
# Your deployed URL (no trailing slash) - used to build notify_url and return_url
NEXT_PUBLIC_APP_URL=https://joblinca.com
